# Loads the jailed-agents dev environment (tools on PATH) when entering this tree.

# Refuse to load unless devshellRoot in the flake matches this checkout.
_here="$PWD"
# the devshellRoot path declared in the flake — the value between the quotes on
#   devshellRoot = "...";
_root="$(awk -F'"' '/^[[:space:]]*devshellRoot[[:space:]]*=/ { print $2; exit }' nix_src/flake.nix)"
if [ "${_root%/}" != "$_here" ]; then
  echo "direnv: ERROR: devshellRoot in nix_src/flake.nix is '${_root:-<unset>}'," >&2
  echo "direnv:        but this checkout is at '$_here'." >&2
  echo "direnv:        Set  devshellRoot = \"$_here\";  in nix_src/flake.nix, then: direnv reload" >&2
  unset _here _root
  exit 1
fi
unset _here _root

watch_file nix_src/flake.nix \
           nix_src/flake.lock \
           nix_src/jailed-agents.nix \
           nix_src/devshell-home.nix

if declare -f use_flake >/dev/null 2>&1; then # if nix-direnv is installed
  use flake ./nix_src
else # no nix direnv (but still nix)
  eval "$(nix print-dev-env ./nix_src)"
fi
