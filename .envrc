# Loads the jailed-agents dev environment (tools on PATH) when entering this tree.

watch_file devshell_tmux_with_jailed_agents/flake.nix \
           devshell_tmux_with_jailed_agents/flake.lock \
           devshell_tmux_with_jailed_agents/jailed-agents.nix \
           devshell_tmux_with_jailed_agents/devshell-home.nix

if declare -f use_flake >/dev/null 2>&1; then # if nix-direnv is installed
  use flake ./devshell_tmux_with_jailed_agents
else # no nix direnv (but still nix)
  eval "$(nix print-dev-env ./devshell_tmux_with_jailed_agents)"
fi
